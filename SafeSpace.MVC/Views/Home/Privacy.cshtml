@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="profile-container">
    <div class="profile-card">

        <h2 class="text-center">Privacy Policy</h2>

        <p class="text-center">
            <strong>Last Updated:</strong> July 7, 2026
        </p>

        <hr />

        <h4>Information We Collect</h4>

        <p>
            When you create an account, SafeSpace stores your username,
            email address, date of birth, and an encrypted version of your
            password. We also store the stories, comments, and likes you
            create while using the website.
        </p>

        <h4>How We Use Your Information</h4>

        <p>
            Your information is used only to provide the features of
            SafeSpace, including creating your account, displaying your
            stories and comments, and allowing interaction with other users.
        </p>

        <h4>Content Moderation</h4>

        <p>
            Usernames, stories, and comments may be checked using an
            automated profanity filter to help maintain a respectful and
            supportive community.
        </p>

        <h4>Password Security</h4>

        <p>
            Passwords are securely hashed before being stored. SafeSpace
            never stores passwords in plain text.
        </p>

        <h4>Account Deletion</h4>

        <p>
            You may delete your account at any time through your profile.
            Once deleted, your account becomes inaccessible.
        </p>

        <h4>Cookies and Sessions</h4>

        <p>
            SafeSpace uses session cookies to keep you signed in while using
            the website. These cookies are required for normal operation.
        </p>

        <h4>Third-Party Services</h4>

        <p>
            SafeSpace uses trusted third-party services for features such as
            profanity filtering and inspirational quotes.
        </p>

        <h4>Changes to This Policy</h4>

        <p>
            This Privacy Policy may be updated from time to time. Any changes
            will be reflected on this page.
        </p>

        <div class="text-center mt-4">

            <a asp-controller="Home"
               asp-action="Index"
               class="btn home-btn">

                Back Home

            </a>

        </div>

    </div>
</div>
